# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (required for production persistence)
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/shoplivebharat?retryWrites=true&w=majority
DB_NAME=shoplivebharat
# Set USE_MEMORY_DB=1 ONLY for local dev without MongoDB
USE_MEMORY_DB=0

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=shoplivebharat-admin
JWT_SECRET=change-me-in-production-use-a-long-random-string
# IMPORTANT: Set HASH_SALT once and NEVER change it — changing it invalidates all passwords
HASH_SALT=change-me-once-and-never-again

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# Default / fallback sender (used for welcome, password, account emails)
SENDER_EMAIL=support@yourdomain.com
SENDER_NAME=ShopLiveBharat
SUPPORT_EMAIL=support@yourdomain.com
# Per-category senders (all addresses must be on a verified domain in Resend)
ORDERS_EMAIL=orders@yourdomain.com
ORDERS_NAME=ShopLiveBharat Orders
SELLERS_EMAIL=sellers@yourdomain.com
SELLERS_NAME=ShopLiveBharat Sellers
BOOKINGS_EMAIL=bookings@yourdomain.com
BOOKINGS_NAME=ShopLiveBharat Bookings
REPLY_TO_EMAIL=support@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ── Google Maps / Places (address autocomplete) ──────────────────────────────
# Server-side only — never exposed to the client. Enable "Places API" for this key.
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
# Set EITHER the single URL (from the Cloudinary dashboard) …
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# … OR the three separate values (leave CLOUDINARY_URL blank if using these):
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Shipping (Shiprocket) ─────────────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
LAUNCH_DATE=2026-06-28T00:00:00+05:30
